# Application
PORT=8080
ASPNETCORE_ENVIRONMENT=Development
Swagger__Enabled=true
Cors__AllowedOrigins=http://localhost:3000

# Required
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=smartsteps;Username=postgres;Password=change-me
Jwt__Key=replace-with-at-least-32-random-characters
Jwt__Issuer=SmartStepsServer
Jwt__Audience=SmartStepsApp

# Google login (OAuth client ID is public, never put a client secret here)
GoogleAuth__ClientId=your-google-oauth-client-id.apps.googleusercontent.com

# Optional email delivery for password recovery
EmailSettings__From=
EmailSettings__Password=
EmailSettings__Host=smtp.gmail.com
EmailSettings__Port=587

# Optional Cloudinary private media
Cloudinary__CloudName=
Cloudinary__ApiKey=
Cloudinary__ApiSecret=
Cloudinary__SignedUrlExpiresInSeconds=300
Cloudinary__ResourceType=video
Cloudinary__DeliveryType=upload

# Optional payOS; mock payments remain available locally when unconfigured
PayOS__ClientId=
PayOS__ApiKey=
PayOS__ChecksumKey=
PayOS__BaseUrl=https://api-merchant.payos.vn
PayOS__ReturnUrl=http://localhost:3000/learning?premiumPayment=success
PayOS__CancelUrl=http://localhost:3000/learning?premiumPayment=cancel
PayOS__PaymentLinkTtlMinutes=30
PayOS__AllowMockPaymentsWhenUnconfigured=true

# Optional AI narrative generation; rule-based reports remain available
DeepSeek__ApiKey=
DeepSeek__BaseUrl=https://api.deepseek.com
DeepSeek__Model=deepseek-v4-flash
DeepSeek__TimeoutSeconds=30
DeepSeek__MaxOutputTokens=1200
